# Choose your backend mode:
# "colab"  - Ollama running on Google Colab GPU (via ngrok)
# "api"    - Use a cloud API like OpenAI, Anthropic, Gemini, Groq, etc.
# "local"  - Run a local model via Ollama
# "hybrid" - Groq (qwen3.6-27b) does vision only, DeepSeek does all
#            reasoning/tool-calling in text — see DeepSeek section below.
BACKEND_MODE=colab

# --- Colab Mode (Ollama on Colab) ---
# The ngrok URL from your Colab notebook (run colab/chitragupt_colab_vlm.ipynb first)
COLAB_OLLAMA_URL=https://your-ngrok-url.ngrok.io
COLAB_VISION_MODEL=qwen3-vl:8b
COLAB_REASON_MODEL=qwen3:8b

# --- Legacy Colab Mode (custom FastAPI server) ---
# COLAB_API_URL=https://your-ngrok-url.ngrok.io
# COLAB_API_KEY=chitragupt-secret-key

# --- API Mode ---
OPENAI_API_KEY=sk-your-key-here
ANTHROPIC_API_KEY=sk-ant-your-key-here
GEMINI_API_KEY=your-gemini-key-here
GROQ_API_KEY=gsk_your-groq-key-here

# Which API provider to use when BACKEND_MODE=api
API_PROVIDER=gemini     # openai | anthropic | gemini | groq
API_MODEL=gemini-flash-latest  # Get your free Gemini key at https://aistudio.google.com/apikey
# For Groq: get a free key at https://console.groq.com/keys, and set e.g.
# API_PROVIDER=groq
# API_MODEL=qwen/qwen3-32b
# (Use a Qwen model, not Llama — Llama models on Groq don't wrap their
# reasoning in <think> tags, so it leaks into the visible response instead
# of being parsed out. GroqBackend is also text-only for now — no images.)

# --- Hybrid Mode (Groq vision + DeepSeek reasoning) ---
# Get a DeepSeek key + credit at https://platform.deepseek.com/api_keys
# Reuses GROQ_API_KEY above for the vision half — only DeepSeek needs a new key.
DEEPSEEK_API_KEY=sk-your-deepseek-key-here
DEEPSEEK_MODEL=deepseek-v4-flash   # or deepseek-v4-pro
GROQ_VISION_MODEL=qwen/qwen3.6-27b
# Set BACKEND_MODE=hybrid to activate this split. Motivation: Groq's free
# tier caps qwen3.6-27b at 8,000 tokens/minute combined input+output, shared
# by image + history + tool schemas + task-list context in one pool — this
# mode keeps only the small, image-only vision call on Groq and moves
# reasoning (which carries all the growing context) to DeepSeek instead,
# which has no comparable per-minute token cap.

# --- Local Mode (Ollama) ---
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=llava:13b

# --- Server ---
HOST=0.0.0.0
PORT=8000
