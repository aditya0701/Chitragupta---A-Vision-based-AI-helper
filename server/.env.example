# Choose your backend mode:
# "colab" - Ollama running on Google Colab GPU (via ngrok)
# "api"   - Use a cloud API like OpenAI, Anthropic, Gemini, etc.
# "local" - Run a local model via Ollama
BACKEND_MODE=colab

# --- Colab Mode (Ollama on Colab) ---
# The ngrok URL from your Colab notebook (run colab/chitragupt_colab_vlm.ipynb first)
COLAB_OLLAMA_URL=https://your-ngrok-url.ngrok.io
COLAB_VISION_MODEL=qwen3-vl:8b
COLAB_REASON_MODEL=qwen3:8b

# --- Legacy Colab Mode (custom FastAPI server) ---
# COLAB_API_URL=https://your-ngrok-url.ngrok.io
# COLAB_API_KEY=chitragupt-secret-key

# --- API Mode ---
OPENAI_API_KEY=sk-your-key-here
ANTHROPIC_API_KEY=sk-ant-your-key-here
GEMINI_API_KEY=your-gemini-key-here
GROQ_API_KEY=gsk_your-groq-key-here

# Which API provider to use when BACKEND_MODE=api
API_PROVIDER=gemini     # openai | anthropic | gemini | groq
API_MODEL=gemini-flash-latest  # Get your free Gemini key at https://aistudio.google.com/apikey
# For Groq: get a free key at https://console.groq.com/keys, and set e.g.
# API_PROVIDER=groq
# API_MODEL=llama-3.3-70b-versatile
# (GroqBackend is text-only for now — no image support yet.)

# --- Local Mode (Ollama) ---
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=llava:13b

# --- Server ---
HOST=0.0.0.0
PORT=8000
